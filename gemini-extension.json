{
  "name": "perplexity-ask",
  "version": "0.9.0",
  "description": "Real-time web search, reasoning, and research through Perplexity's API",
  "mcpServers": {
    "perplexity": {
      "command": "node",
      "args": [
        "${extensionPath}${/}dist${/}index.js"
      ],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    }
  }
}
